# ─── Required ────────────────────────────────────────────────────────────────

# BIP-39 seed phrase (12 or 24 words).
# Wallets are derived from this phrase. NEVER commit this value.
SEED_PHRASE=

# Polygon JSON-RPC URL.
# Phase 1 (Amoy testnet, chainId 80002):
POLYGON_RPC=https://rpc-amoy.polygon.technology
# Phase 2 (mainnet, chainId 137) – just swap the line above with:
# POLYGON_RPC=https://polygon-rpc.com

# ERC-20 USD₮ token contract address on the target network.
# Phase 1 (Amoy) – deploy or use a mock ERC-20 on Amoy and paste its address here.
# Phase 2 (mainnet) – canonical Polygon USDT:
# USDT_TOKEN_ADDRESS=0xc2132D05D31c914a87C6611C10748AEb04B58e8F
USDT_TOKEN_ADDRESS=

# ─── Optional ────────────────────────────────────────────────────────────────

# Port the HTTP server listens on (default: 3001)
PORT=3001
