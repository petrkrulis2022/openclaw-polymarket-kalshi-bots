# Copy-Trader Bot — environment variables
PORT=3004
BOT_ID=3

# Set to "true" to run without submitting real orders
PAPER_TRADING=true

# Polymarket CLOB credentials (same as market-maker)
POLYMARKET_WALLET_ADDRESS=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# Set this to enable live trading (removes paper-trading mode automatically)
BOT_SIGNER_KEY=

ORCHESTRATOR_URL=http://localhost:3002
TREASURY_URL=http://localhost:3001
