# Polymarket credentials
POLYMARKET_WALLET_ADDRESS=0x...
POLYMARKET_API_KEY=your-api-key
POLYMARKET_API_SECRET=your-secret
POLYMARKET_API_PASSPHRASE=your-passphrase

# Private key for signing on-chain orders (must match POLYMARKET_WALLET_ADDRESS)
# Leave blank to stay in paper-trading mode
BOT_PRIVATE_KEY=

# Bot settings
BOT_ID=1
PAPER_TRADING=true
PORT=3003

# Upstream services
ORCHESTRATOR_URL=http://localhost:3002
TREASURY_URL=http://localhost:3001

# Quoting parameters
QUOTE_WIDTH_MULTIPLIER=1.2
NUM_MARKETS=5
MIN_VOLUME_24H=10000
METRICS_INTERVAL_MS=30000
POLL_INTERVAL_MS=5000
